# SevaSetu Backend – Environment Variables
# Copy this to .env and fill in your values

# Database – SQLite for local dev (no Postgres needed)
DATABASE_URL=sqlite:///./sevasetu.db

# JWT – change SECRET_KEY in production!
SECRET_KEY=your-32-char-secret-change-me-now!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Dataset paths (use cleaned version)
KNOWLEDGE_BASE_PATH=./data/schemes_cleaned.json
FAISS_INDEX_PATH=./data/faiss.index

# === LLM API KEY (required for AI responses) ===
# Get your key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Voice
AUDIO_OUTPUT_DIR=./static/audio

# Debug
DEBUG=True
