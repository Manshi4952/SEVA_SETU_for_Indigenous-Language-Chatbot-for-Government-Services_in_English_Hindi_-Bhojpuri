# SevaSetu Backend – Local Development Environment

# Use SQLite for local dev (no PostgreSQL needed)
DATABASE_URL=sqlite:///./sevasetu.db

# JWT secret – change in production!
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Dataset & AI model paths
KNOWLEDGE_BASE_PATH=./data/schemes.json
FAISS_INDEX_PATH=./data/faiss.index

# Audio output
AUDIO_OUTPUT_DIR=./static/audio

# Debug
DEBUG=True

# Add your Telegram bot token here for local testing
TELEGRAM_BOT_TOKEN = ""  
