# ============================================================
# SevaSetu Backend – Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///./sevasetu.db

# ── Auth ─────────────────────────────────────────────────────
# Change SECRET_KEY in production — must be 32+ random chars
SECRET_KEY=your-32-char-secret-change-me-now!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Dataset paths ────────────────────────────────────────────
KNOWLEDGE_BASE_PATH=./data/schemes_cleaned.json
FAISS_INDEX_PATH=./data/faiss.index

# ── LLM Provider ─────────────────────────────────────────────
# Options: "groq" (cloud, default) | "ollama" (local fine-tuned)
LLM_PROVIDER=groq

# ── Groq (Approach 1 & 2) ────────────────────────────────────
# Get a free key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# Model options:
#   llama-3.3-70b-versatile  → best quality (default)
#   llama-3.1-8b-instant     → faster, lower quality
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=700
LLM_TEMPERATURE=0.4

# ── Ollama / Fine-tuned model (Approach 3) ───────────────────
# After fine-tuning on Colab and setting up Ollama locally:
#   1. Set LLM_PROVIDER=ollama
#   2. Set OLLAMA_MODEL=sevasetu (or your model name)
#   3. Keep GROQ_API_KEY as fallback
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=sevasetu

# ── Voice ─────────────────────────────────────────────────────
AUDIO_OUTPUT_DIR=./static/audio

# ── Debug ────────────────────────────────────────────────────
DEBUG=True

# ── Together AI (Option B fine-tuning) ───────────────────────
# Sign up free at https://api.together.ai ($25 credits)
# After training completes, set LLM_PROVIDER=together
TOGETHER_API_KEY=
TOGETHER_MODEL=

# ── HuggingFace (Option C fine-tuning) ───────────────────────
# Get token at https://huggingface.co/settings/tokens
HF_TOKEN=
HF_USERNAME=your_hf_username
